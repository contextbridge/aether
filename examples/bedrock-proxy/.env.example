# Copy to .env and fill in values for the runnable example.
# AWS credentials are exported by `just bedrock-proxy-run`; leave them out of this file.

AWS_REGION=us-west-2
BEDROCK_PROXY_PORT=8080

# Use a Bedrock model ID or application inference profile ARN.
# Example ARN format:
# arn:aws:bedrock:us-west-2:000000000000:application-inference-profile/REPLACE_ME
AETHER_BEDROCK_MODEL=arn:aws:bedrock:us-west-2:352243939980:application-inference-profile/6b3k0me2dlm2

AETHER_BEDROCK_PROMPT="Say hello in one sentence and mention that this response came through Bedrock."

