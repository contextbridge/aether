{
  "name": "@aether-agent/sdk",
  "version": "0.2.1",
  "description": "TypeScript SDK for the Aether agent CLI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contextbridge/aether.git",
    "directory": "packages/aether-sdk"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm generate:settings-types && tsc -p tsconfig.build.json",
    "typecheck": "pnpm generate:settings-types && tsc -p tsconfig.json --noEmit",
    "test": "pnpm generate:settings-types && vitest run",
    "generate:settings-types": "node scripts/generate-settings-types.mjs",
    "e2e": "node scripts/e2e.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "quicktype-core": "^23.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
