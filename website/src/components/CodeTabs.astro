---
interface Props {
  labels: string[];
  class?: string;
}

const { labels, class: className } = Astro.props;
const hasFooter = Astro.slots.has("footer");
---

<div
  class:list={[
    "code-tabs overflow-hidden rounded-lg border border-gray-500 bg-transparent",
    className,
  ]}
  data-code-tabs
>
  <div class="flex gap-6 bg-transparent px-3" role="tablist">
    {
      labels.map((label, i) => (
        <button
          class="cursor-pointer border-0 border-b-2 border-transparent bg-transparent py-3 pb-2 font-mono text-xs tracking-[0.08em] text-gray-400 uppercase transition-colors duration-150 hover:text-gray-200 aria-selected:border-accent-500 aria-selected:text-accent-500"
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          data-tab-index={i}
        >
          {label}
        </button>
      ))
    }
  </div>
  <div class="code-tabs-panels relative">
    <slot />
  </div>
  {
    hasFooter && (
      <div class="flex items-center gap-3 border-t border-gray-700 bg-transparent px-3 py-2 font-mono text-xs leading-none font-medium tracking-[0.08em] text-gray-400 uppercase">
        <slot name="footer" />
      </div>
    )
  }
</div>

<style>
  @reference '../styles/global.css';

  .code-tabs-panels :global(.expressive-code) {
    margin-top: 0 !important;
  }

  .code-tabs-panels :global(.expressive-code .frame),
  .code-tabs-panels :global(.expressive-code .header),
  .code-tabs-panels :global(.expressive-code pre),
  .code-tabs-panels :global(.expressive-code .code) {
    @apply rounded-none border-0 shadow-none;
  }

  .code-tabs-panels :global(.expressive-code pre) {
    @apply bg-transparent text-gray-50;
  }

  .code-tabs-panels :global(.expressive-code code span) {
    @apply text-gray-50;
  }

  .code-tabs-panels :global(.expressive-code .ec-line .code > span:first-child) {
    @apply text-accent-500;
  }

  .code-tabs-panels :global(.expressive-code .copy button) {
    @apply bg-transparent;
  }

  .code-tabs-panels :global(.expressive-code .copy button div) {
    @apply bg-gray-400;
  }

  .code-tabs-panels :global(.expressive-code .copy button:hover div) {
    @apply bg-accent-500;
  }

  .code-tabs-panels :global(.expressive-code .copy) {
    top: 50% !important;
    right: 0.5rem !important;
    bottom: auto !important;
    transform: translateY(-50%);
  }

  .code-tabs-panels :global(.expressive-code .frame.is-terminal .header) {
    display: none !important;
  }

  .code-tabs-panels :global(.expressive-code[data-hidden]) {
    visibility: hidden;
    position: absolute;
    inset-inline: 0;
    top: 0;
    pointer-events: none;
  }
</style>

<script>
  document.querySelectorAll("[data-code-tabs]").forEach((root) => {
    const buttons = root.querySelectorAll<HTMLButtonElement>("[role=tab]");
    const panels = root.querySelectorAll<HTMLElement>(
      ".code-tabs-panels > .expressive-code",
    );

    function activate(index: number) {
      buttons.forEach((btn, i) => {
        btn.setAttribute("aria-selected", String(i === index));
      });
      panels.forEach((panel, i) => {
        if (i === index) {
          panel.removeAttribute("data-hidden");
        } else {
          panel.setAttribute("data-hidden", "");
        }
      });
    }

    activate(0);

    root.querySelector("[role=tablist]")!.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
        "[role=tab]",
      );
      if (btn) activate(Number(btn.dataset.tabIndex));
    });
  });
</script>
