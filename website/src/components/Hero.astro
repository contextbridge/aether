---
import TerminalDemo from "./TerminalDemo.astro";
import InstallTabs from "./InstallTabs.astro";
import LandingButton from "./LandingButton.astro";
import { Icon } from "astro-icon/components";
import { GITHUB_URL } from "../consts";
---

<section class="px-16 pt-16 pb-16 sm:pt-28 sm:pb-20">
  <div class="mx-auto max-w-350">
    <div
      class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[5fr_7fr] lg:gap-16"
    >
      <div class="flex flex-col gap-6 text-center lg:text-left">
        <h1
          class="m-0 font-mono text-2xl font-semibold text-white sm:text-4xl lg:text-5xl"
        >
          The open-source coding agent <span class="italic underline">you</span> control
        </h1>
        <p class="m-0 text-base text-gray-400 sm:text-lg lg:text-xl">
          Aether is a modular agent that gives you control over every token in
          context. Switch from minimal to batteries-included with a few lines of
          config. Run it in a TUI, IDE, or headlessly.
        </p>

        <div class="mx-auto w-full max-w-lg lg:mx-0">
          <InstallTabs />
        </div>

        <div class="flex flex-wrap justify-center gap-4 lg:justify-start">
          <LandingButton href="/getting-started/overview/">
            <Icon slot="leading" name="lucide:file-text" size={18} />
            Docs
            <Icon slot="trailing" name="lucide:chevron-right" size={18} />
          </LandingButton>
          <LandingButton href={GITHUB_URL} variant="secondary">
            <Icon slot="leading" name="simple-icons:github" size={18} />
            GitHub
            <Icon slot="trailing" name="lucide:chevron-right" size={18} />
          </LandingButton>
        </div>
      </div>

      <TerminalDemo
        id="hero-player"
        src="/demos/demo.cast"
        class="shadow-none"
      />
    </div>
  </div>
</section>
